<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posiciones | Quiniela Mundial 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="w-full min-h-screen text-slate-100 font-sans bg-slate-950 flex flex-col relative">

    <%- include('partials/header') %>

    <!-- Background Layer -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed opacity-30" style="background-image: url('/images/stadium_bg.jpeg');"></div>
        <div class="absolute inset-0 bg-slate-950/90"></div>
    </div>

    <main class="flex-grow w-full max-w-7xl mx-auto px-6 py-10 relative z-10">
        
        <!-- Header de la Página -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 pb-6 border-b border-white/5">
            <div>
                <h1 class="text-3xl md:text-4xl font-black text-white flex items-center mb-2">
                    <i class="fa-solid fa-trophy text-amber-500 mr-4 drop-shadow-md"></i>
                    Posiciones de la Quiniela
                </h1>
                <p class="text-slate-400 text-sm md:text-base">Resultados actualizados en tiempo real según el puntaje de la FIFA.</p>
            </div>
            
            <div class="mt-4 md:mt-0 flex items-center space-x-3 bg-slate-900/50 border border-white/10 px-4 py-2.5 rounded-lg backdrop-blur-md">
                <i class="fa-regular fa-clock text-slate-400 text-lg"></i>
                <div class="flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-slate-500 tracking-wider">Última actualización</span>
                    <% 
                        const now = new Date();
                        const dateString = now.toLocaleDateString('es-VE', { day: '2-digit', month: 'short', year: 'numeric' });
                        const timeString = now.toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    %>
                    <span class="text-xs font-medium text-slate-300"><%= dateString %> - <%= timeString %></span>
                </div>
            </div>
        </div>

        <!-- Tabla de Clasificación Premium -->
        <div class="w-full overflow-hidden">
            <!-- Table Header -->
            <div class="hidden md:grid grid-cols-12 gap-4 bg-blue-900/80 backdrop-blur-md rounded-t-xl px-6 py-4 border-b border-blue-800">
                <div class="col-span-1 text-xs font-bold text-white uppercase tracking-widest text-center">Puesto</div>
                <div class="col-span-5 lg:col-span-4 text-xs font-bold text-white uppercase tracking-widest">Participante</div>
                <div class="col-span-2 lg:col-span-3 text-xs font-bold text-white uppercase tracking-widest text-center">Resultados Exactos (3 pts)</div>
                <div class="col-span-2 text-xs font-bold text-white uppercase tracking-widest text-center">Aciertos Simples (1 pt)</div>
                <div class="col-span-2 text-xs font-bold text-white uppercase tracking-widest text-center">Puntos Totales</div>
            </div>

            <!-- Table Body -->
            <div class="space-y-2 mt-2">
                <% rankings.forEach((r, index) => { %>
                    <% 
                        const isFirst = index === 0;
                        const isSecond = index === 1;
                        const isThird = index === 2;
                        
                        let rowClasses = "grid grid-cols-1 md:grid-cols-12 gap-4 items-center bg-slate-900/75 backdrop-blur-md border px-6 py-4 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_0_15px_rgba(37,99,235,0.25)] ";
                        
                        if (isFirst) {
                            rowClasses += "border-amber-400 rounded-lg shadow-[0_0_20px_rgba(245,158,11,0.15)] z-10 relative";
                        } else {
                            rowClasses += "border-white/5 rounded-lg";
                        }
                    %>
                    
                    <div class="<%= rowClasses %>">
                        
                        <!-- Puesto -->
                        <div class="col-span-1 flex items-center justify-center">
                            <% if (isFirst) { %>
                                <div class="flex flex-col items-center justify-center text-amber-500">
                                    <i class="fa-solid fa-trophy text-2xl drop-shadow-[0_0_8px_rgba(245,158,11,0.6)] mb-1"></i>
                                    <span class="text-xs font-black">#1</span>
                                </div>
                            <% } else if (isSecond) { %>
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-slate-300 to-slate-400 flex items-center justify-center shadow-lg border border-slate-300">
                                    <span class="text-slate-900 font-black text-sm">2</span>
                                </div>
                            <% } else if (isThird) { %>
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-600 to-amber-700 flex items-center justify-center shadow-lg border border-amber-500">
                                    <span class="text-white font-black text-sm">3</span>
                                </div>
                            <% } else { %>
                                <span class="text-lg font-black text-slate-400"><%= index + 1 %></span>
                            <% } %>
                        </div>
                        
                        <!-- Participante -->
                        <div class="col-span-5 lg:col-span-4 flex items-center space-x-4 mt-4 md:mt-0">
                            <!-- Avatar -->
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white shadow-md bg-blue-600">
                                <%= r.first_name.charAt(0).toUpperCase() %>
                            </div>
                            <!-- Name -->
                            <span class="text-base font-bold text-white"><%= r.first_name %> <%= r.last_name %></span>
                        </div>

                        <!-- Exactos -->
                        <div class="col-span-2 lg:col-span-3 flex justify-between md:justify-center items-center mt-2 md:mt-0">
                            <span class="md:hidden text-xs text-slate-500 font-bold uppercase w-1/2">Resultados Exactos:</span>
                            <span class="text-lg font-black text-emerald-500"><%= r.exact_matches_count %></span>
                        </div>

                        <!-- Simples -->
                        <div class="col-span-2 flex justify-between md:justify-center items-center mt-2 md:mt-0">
                            <span class="md:hidden text-xs text-slate-500 font-bold uppercase w-1/2">Aciertos Simples:</span>
                            <span class="text-lg font-black text-orange-500"><%= r.outcome_matches_count %></span>
                        </div>

                        <!-- Total -->
                        <div class="col-span-2 flex justify-between md:justify-center items-center mt-2 md:mt-0">
                            <span class="md:hidden text-xs text-slate-500 font-bold uppercase w-1/2">Total:</span>
                            <span class="text-xl font-black <%= isFirst ? 'text-amber-500' : 'text-white' %>">
                                <%= r.total_points %> <span class="text-[10px] text-slate-500 font-bold">pts</span>
                            </span>
                        </div>

                    </div>
                <% }) %>
                
                <% if(rankings.length === 0) { %>
                    <div class="bg-slate-900/75 backdrop-blur-md border border-white/5 rounded-lg px-6 py-12 text-center">
                        <i class="fa-solid fa-ghost text-4xl text-slate-700 mb-4"></i>
                        <p class="text-slate-400 font-medium text-lg">Aún no hay participantes en la tabla de posiciones.</p>
                    </div>
                <% } %>
            </div>
        </div>

    </main>

    <div class="relative z-20 border-t border-white/10 bg-slate-950/90 mt-10">
        <%- include('partials/footer') %>
    </div>
</body>
</html>
