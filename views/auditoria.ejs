<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoría | Quiniela Mundial 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="bg-cover bg-center bg-no-repeat bg-fixed font-sans min-h-screen relative text-slate-100" style="background-image: url('/images/stadium_bg.jpeg');">
    
    <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm z-0 pointer-events-none"></div>

    <div class="relative z-10 flex flex-col min-h-screen">
        <%- include('partials/header', { user: user, activePage: 'auditoria' }) %>

        <main class="flex-grow max-w-6xl mx-auto w-full px-6 py-10">
            
            <div class="mb-8">
                <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-slate-700/60 pb-4">
                    <div>
                        <div class="flex items-center space-x-2 mb-2">
                            <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)]"></div>
                            <span class="text-xs font-bold text-slate-400 tracking-widest uppercase">Fase de Grupos <span class="mx-1 text-slate-500">|</span> Mundial 2026</span>
                        </div>
                        <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight uppercase">REGISTRO DE AUDITORÍA</h1>
                    </div>
                    <div class="mt-4 md:mt-0">
                        <div class="bg-slate-900/80 border border-slate-700/50 px-4 py-2 rounded-lg text-xs text-slate-400 font-medium shadow-inner backdrop-blur-sm">
                            Zona Horaria: <span class="font-bold text-white ml-1">VET (Caracas)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900/70 border border-white/5 rounded-3xl p-6 backdrop-blur-md shadow-2xl overflow-hidden">
                <div class="flex justify-between items-center mb-6 px-2 border-b border-slate-800 pb-4">
                    <h3 class="text-lg font-bold text-white flex items-center space-x-2">
                        <i class="fa-solid fa-list-check text-emerald-500"></i>
                        <span>Modificaciones de Pronósticos</span>
                    </h3>
                    <div class="bg-blue-600/20 text-blue-400 px-3 py-1 rounded-full text-xs font-bold border border-blue-500/30">
                        <%= auditLogs.length %> registros encontrados
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="text-xs uppercase text-slate-400 bg-slate-950/50">
                            <tr>
                                <th scope="col" class="px-6 py-4 rounded-tl-xl font-bold tracking-wider">Usuario</th>
                                <th scope="col" class="px-6 py-4 text-center font-bold tracking-wider">Partido</th>
                                <th scope="col" class="px-6 py-4 text-center font-bold tracking-wider">Predicción</th>
                                <th scope="col" class="px-6 py-4 text-right rounded-tr-xl font-bold tracking-wider">Fecha de Actualización</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/50">
                            <% if(auditLogs && auditLogs.length > 0) { %>
                                <% auditLogs.forEach(log => { %>
                                    <tr class="hover:bg-slate-800/40 transition-colors group">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center space-x-3">
                                                <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center font-bold text-white text-xs shadow-md">
                                                    <%= log.first_name ? log.first_name.charAt(0).toUpperCase() : 'U' %>
                                                </div>
                                                <span class="font-bold text-white"><%= log.first_name %> <%= log.last_name %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center justify-center space-x-2">
                                                <% if(log.home_iso) { %>
                                                    <img src="https://flagcdn.com/w40/<%= log.home_iso %>.png" class="w-5 h-3.5 object-cover rounded-[2px]" alt="<%= log.home_team %>">
                                                <% } %>
                                                <span class="text-xs font-bold text-slate-300"><%= log.home_team %></span>
                                                <span class="text-[10px] text-slate-500 font-black px-1">VS</span>
                                                <span class="text-xs font-bold text-slate-300"><%= log.away_team %></span>
                                                <% if(log.away_iso) { %>
                                                    <img src="https://flagcdn.com/w40/<%= log.away_iso %>.png" class="w-5 h-3.5 object-cover rounded-[2px]" alt="<%= log.away_team %>">
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <div class="inline-flex items-center space-x-2 bg-slate-950/60 border border-slate-700 px-3 py-1.5 rounded-lg shadow-inner">
                                                <span class="text-emerald-400 font-black text-sm w-4 text-center"><%= log.home_score %></span>
                                                <span class="text-slate-600 text-xs">-</span>
                                                <span class="text-emerald-400 font-black text-sm w-4 text-center"><%= log.away_score %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex flex-col items-end">
                                                <span class="text-xs font-bold text-white">
                                                    <%= new Date(log.created_at).toLocaleDateString('es-VE', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </span>
                                                <span class="text-[10px] font-medium text-slate-400 mt-0.5 flex items-center">
                                                    <i class="fa-regular fa-clock mr-1 text-slate-500"></i>
                                                    <%= new Date(log.created_at).toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                                                </span>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-slate-500">
                                        <i class="fa-solid fa-clipboard-list text-4xl mb-3 opacity-50"></i>
                                        <p class="text-sm font-medium">Aún no se han registrado modificaciones en las predicciones.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
