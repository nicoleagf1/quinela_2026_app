<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración | Quiniela Mundial 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(15, 23, 42, 0.5); }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(51, 65, 85, 0.8); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(71, 85, 105, 1); }
    </style>

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-950 font-sans min-h-screen text-slate-100 flex overflow-hidden">
    
    <!-- Fondo estático con desenfoque -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/stadium_bg.jpeg');"></div>
        <div class="absolute inset-0 bg-slate-950/85 backdrop-blur-sm"></div>
    </div>

    <!-- Sidebar -->
    <%- include('../partials/admin_sidebar', { activePage: 'dashboard' }) %>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col relative z-10 h-screen overflow-hidden">
        
        <!-- Header Administrativo -->
        <header class="bg-slate-900/60 border-b border-white/5 px-4 md:px-8 py-5 flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0 backdrop-blur-md z-20 shadow-lg">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center">
                    <i class="fa-solid fa-shield-halved text-blue-500 text-xl"></i>
                </div>
                <div>
                    <h1 class="text-xl font-black text-white tracking-tight">Panel de Control General</h1>
                    <p class="text-xs text-slate-400 font-medium">Resumen completo del sistema de la Quiniela Mundial 2026</p>
                </div>
            </div>

            <div class="flex items-center space-x-6">
                <div class="flex items-center space-x-3 text-right">
                    <i class="fa-regular fa-clock text-slate-500 text-xl"></i>
                    <div>
                        <p class="text-[10px] uppercase font-bold text-slate-500 tracking-wider">Última actualización</p>
                        <% 
                            const now = new Date();
                            const dateString = now.toLocaleDateString('es-VE', { day: '2-digit', month: 'short', year: 'numeric' });
                            const timeString = now.toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                        %>
                        <p class="text-xs font-medium text-slate-300"><%= dateString %> - <%= timeString %></p>
                    </div>
                </div>
                
                <div class="h-8 w-px bg-white/10"></div>
                
                <div class="flex items-center space-x-4">
                    <button class="relative text-slate-400 hover:text-white transition-colors">
                        <i class="fa-solid fa-bell text-xl"></i>
                        <span class="absolute -top-1 -right-1 w-4 h-4 bg-amber-500 rounded-full border-2 border-slate-900 text-[8px] font-black flex items-center justify-center text-slate-950">3</span>
                    </button>
                    <div class="relative group cursor-pointer">
                        <div class="flex items-center space-x-2 hover:bg-white/5 p-1.5 rounded-lg transition-colors">
                            <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center font-bold text-white text-xs shadow-md">AD</div>
                            <span class="text-sm font-bold text-white hidden md:block">Administrador <i class="fa-solid fa-chevron-down text-[10px] ml-1 text-slate-400 group-hover:rotate-180 transition-transform duration-300"></i></span>
                        </div>
                        <div class="absolute right-0 mt-1 w-48 bg-slate-900 border border-slate-700 rounded-xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)] py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 origin-top-right transform scale-95 group-hover:scale-100">
                            <div class="px-4 py-2 border-b border-slate-700/50 mb-1">
                                <p class="text-xs font-bold text-white uppercase tracking-wider">Opciones</p>
                            </div>
                            <a href="/dashboard" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-white/5 hover:text-white transition-colors">
                                <i class="fa-solid fa-house w-5 text-center text-blue-500 mr-2"></i> Ir al Sitio Público
                            </a>
                            <div class="my-1 border-t border-slate-700/50"></div>
                            <a href="/logout" class="flex items-center px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors">
                                <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center mr-2"></i> Cerrar Sesión
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Scrollable Dashboard Content -->
        <div class="flex-1 overflow-y-auto custom-scrollbar p-8">
            <div class="max-w-[1600px] mx-auto space-y-8 pb-10">
                
                <!-- 1. KPIs Principales (4 Tarjetas) -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    
                    <!-- KPI 1: Usuarios -->
                    <div class="relative overflow-hidden rounded-2xl border border-blue-500/30 bg-slate-900/80 p-6 shadow-[0_0_20px_rgba(37,99,235,0.1)] backdrop-blur-md group">
                        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/10 to-transparent opacity-50"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center border border-blue-500/30 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-users text-blue-500 text-xl"></i>
                                </div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Usuarios Activos</p>
                            </div>
                            <h3 class="text-4xl font-black text-white mb-2"><%= metrics.totalUsers.toLocaleString() %></h3>
                            <div class="flex items-center text-[10px] font-bold text-emerald-400 bg-emerald-400/10 w-fit px-2 py-1 rounded-md border border-emerald-400/20">
                                <i class="fa-solid fa-arrow-trend-up mr-1"></i> +12.5% desde la última semana
                            </div>
                        </div>
                    </div>

                    <!-- KPI 2: Predicciones -->
                    <div class="relative overflow-hidden rounded-2xl border border-emerald-500/30 bg-slate-900/80 p-6 shadow-[0_0_20px_rgba(16,185,129,0.1)] backdrop-blur-md group">
                        <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/10 to-transparent opacity-50"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <div class="w-12 h-12 rounded-xl bg-emerald-600/20 flex items-center justify-center border border-emerald-500/30 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-check-double text-emerald-500 text-xl"></i>
                                </div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Predicciones Hechas</p>
                            </div>
                            <h3 class="text-4xl font-black text-white mb-2"><%= metrics.totalPredictions.toLocaleString() %></h3>
                            <div class="flex items-center text-[10px] font-bold text-emerald-400 bg-emerald-400/10 w-fit px-2 py-1 rounded-md border border-emerald-400/20">
                                <i class="fa-solid fa-arrow-trend-up mr-1"></i> +8.2% de participación por partido
                            </div>
                        </div>
                    </div>

                    <!-- KPI 3: Partidos Finalizados -->
                    <div class="relative overflow-hidden rounded-2xl border border-purple-500/30 bg-slate-900/80 p-6 shadow-[0_0_20px_rgba(168,85,247,0.1)] backdrop-blur-md group">
                        <div class="absolute inset-0 bg-gradient-to-br from-purple-600/10 to-transparent opacity-50"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <div class="w-12 h-12 rounded-xl bg-purple-600/20 flex items-center justify-center border border-purple-500/30 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-futbol text-purple-500 text-xl"></i>
                                </div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right">Partidos Finalizados</p>
                            </div>
                            <h3 class="text-4xl font-black text-white mb-2"><%= metrics.finishedMatches %> <span class="text-xl text-slate-500 font-bold">/ 104</span></h3>
                            <div class="flex items-center text-[10px] font-bold text-slate-400 bg-slate-800 w-fit px-2 py-1 rounded-md border border-slate-700">
                                <%= Math.round((metrics.finishedMatches / 104) * 100) %>% del total del torneo
                            </div>
                        </div>
                    </div>

                    <!-- KPI 4: Puntos Calculados -->
                    <div class="relative overflow-hidden rounded-2xl border border-amber-500/40 bg-gradient-to-br from-amber-500/20 to-slate-900/80 p-6 shadow-[0_0_25px_rgba(245,158,11,0.15)] backdrop-blur-md group">
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-amber-400/10 via-transparent to-transparent"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <div class="w-12 h-12 rounded-xl bg-amber-500/20 flex items-center justify-center border border-amber-400/50 group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(245,158,11,0.3)]">
                                    <i class="fa-solid fa-medal text-amber-500 text-xl"></i>
                                </div>
                                <p class="text-[10px] font-bold text-amber-500/80 uppercase tracking-widest">Puntos Calculados</p>
                            </div>
                            <h3 class="text-4xl font-black text-white mb-2 drop-shadow-md">98.74%</h3>
                            <div class="flex items-center text-[10px] font-bold text-amber-400 bg-amber-500/10 w-fit px-2 py-1 rounded-md border border-amber-500/30">
                                <i class="fa-solid fa-microchip mr-1"></i> Automatización del sistema activa
                            </div>
                        </div>
                    </div>

                </div>

                <!-- 2. Centro de Control (3 Columnas) -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    
                    <!-- Columna Izquierda: Top Usuarios (5 cols) -->
                    <div class="lg:col-span-5 bg-slate-900/70 border border-white/5 rounded-2xl p-6 backdrop-blur-md flex flex-col shadow-xl">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-sm font-bold text-white flex items-center space-x-2">
                                <i class="fa-solid fa-chart-simple text-blue-500"></i>
                                <span>Control de Puntuaciones de Usuarios</span>
                            </h3>
                            <a href="/admin/users" class="text-[10px] bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-md border border-slate-700 transition-colors">Ver todos</a>
                        </div>
                        
                        <div class="flex-grow">
                            <div class="grid grid-cols-12 gap-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 px-2">
                                <div class="col-span-2 text-center">Pos</div>
                                <div class="col-span-4">Usuario</div>
                                <div class="col-span-2 text-center">Exactas</div>
                                <div class="col-span-2 text-center">Simples</div>
                                <div class="col-span-2 text-right">Puntos</div>
                            </div>
                            
                            <div class="space-y-2">
                                <% usersList.slice(0, 5).forEach((user, index) => { %>
                                    <div class="grid grid-cols-12 gap-2 items-center bg-slate-950/50 hover:bg-slate-800/50 border border-white/5 p-2 rounded-xl transition-colors">
                                        <div class="col-span-2 flex justify-center">
                                            <% if(index === 0) { %>
                                                <i class="fa-solid fa-medal text-amber-500 text-lg drop-shadow-[0_0_5px_rgba(245,158,11,0.5)]"></i>
                                            <% } else if(index === 1) { %>
                                                <i class="fa-solid fa-medal text-slate-300 text-lg"></i>
                                            <% } else if(index === 2) { %>
                                                <i class="fa-solid fa-medal text-amber-700 text-lg"></i>
                                            <% } else { %>
                                                <span class="text-sm font-black text-slate-500"><%= index + 1 %></span>
                                            <% } %>
                                        </div>
                                        <div class="col-span-4 flex items-center space-x-2 truncate">
                                            <div class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0">
                                                <%= user.first_name.charAt(0).toUpperCase() %>
                                            </div>
                                            <span class="text-xs font-bold text-white truncate"><%= user.first_name %> <%= user.last_name %></span>
                                        </div>
                                        <div class="col-span-2 text-center text-xs font-black text-emerald-500"><%= user.exact_matches_count %></div>
                                        <div class="col-span-2 text-center text-xs font-black text-orange-500"><%= user.outcome_matches_count %></div>
                                        <div class="col-span-2 text-right text-sm font-black text-blue-400"><%= user.total_points %><span class="text-[8px] text-slate-500 ml-0.5">pts</span></div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        
                        <a href="/admin/users" class="mt-4 block w-full py-2.5 border border-blue-500/30 text-blue-400 hover:bg-blue-600/10 text-xs font-bold text-center rounded-xl transition-colors">
                            <i class="fa-solid fa-gear mr-1"></i> Gestionar Puntuaciones
                        </a>
                    </div>

                    <!-- Columna Centro: Monitoreo Partidos (4 cols) -->
                    <div class="lg:col-span-4 bg-slate-900/70 border border-white/5 rounded-2xl p-6 backdrop-blur-md flex flex-col shadow-xl">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-sm font-bold text-white flex items-center space-x-2">
                                <i class="fa-solid fa-play-circle text-emerald-500"></i>
                                <span>Monitoreo de Partidos</span>
                            </h3>
                            <a href="/admin/matches" class="text-[10px] bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-md border border-slate-700 transition-colors">Ver todos</a>
                        </div>
                        
                        <div class="flex-grow space-y-3">
                            <% criticalMatches.slice(0, 3).forEach(match => { %>
                                <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-4">
                                    <div class="flex justify-between items-center mb-3">
                                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"><%= match.stage %></span>
                                        <% if (match.status === 'live') { %>
                                            <span class="text-[8px] uppercase font-black px-2 py-0.5 rounded border border-red-500/50 text-red-400 bg-red-500/10 animate-pulse">En Vivo</span>
                                        <% } else { %>
                                            <span class="text-[8px] uppercase font-black px-2 py-0.5 rounded border border-emerald-500/50 text-emerald-400 bg-emerald-500/10">Programado</span>
                                        <% } %>
                                    </div>
                                    
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-2 w-5/12">
                                            <% if(teamData && teamData[match.home_team]) { %>
                                                <img src="https://flagcdn.com/w40/<%= teamData[match.home_team].iso %>.png" class="w-5 h-3.5 object-cover rounded-[2px]" alt="Flag">
                                            <% } %>
                                            <span class="text-xs font-bold text-white truncate"><%= match.home_team %></span>
                                        </div>
                                        <span class="text-[10px] font-black text-slate-600">VS</span>
                                        <div class="flex items-center space-x-2 w-5/12 flex-row-reverse">
                                            <% if(teamData && teamData[match.away_team]) { %>
                                                <img src="https://flagcdn.com/w40/<%= teamData[match.away_team].iso %>.png" class="w-5 h-3.5 object-cover rounded-[2px] ml-2" alt="Flag">
                                            <% } %>
                                            <span class="text-xs font-bold text-white truncate"><%= match.away_team %></span>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-3 text-[10px] text-slate-400 flex items-center space-x-1">
                                        <i class="fa-regular fa-calendar text-slate-500"></i>
                                        <span><%= new Date(match.kickoff_time).toLocaleDateString('es-VE', { day: '2-digit', month: 'short', year: 'numeric' }) %> - <%= new Date(match.kickoff_time).toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'}) %></span>
                                    </div>
                                </div>
                            <% }) %>
                            <% if(criticalMatches.length === 0) { %>
                                <p class="text-slate-500 text-xs text-center py-4">No hay partidos críticos.</p>
                            <% } %>
                        </div>
                        
                        <a href="/admin/matches/center" class="mt-4 block w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold text-center rounded-xl transition-colors shadow-lg shadow-blue-500/20">
                            <i class="fa-solid fa-futbol mr-1"></i> Ver todos los partidos
                        </a>
                    </div>

                    <!-- Columna Derecha: Actividad Reciente (3 cols) -->
                    <div class="lg:col-span-3 bg-slate-900/70 border border-white/5 rounded-2xl p-6 backdrop-blur-md flex flex-col shadow-xl">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-sm font-bold text-white flex items-center space-x-2">
                                <i class="fa-solid fa-bolt text-amber-500"></i>
                                <span>Actividad Reciente</span>
                            </h3>
                        </div>
                        
                        <div class="flex-grow relative">
                            <!-- Línea de timeline -->
                            <div class="absolute left-[15px] top-2 bottom-2 w-px bg-slate-800"></div>
                            
                            <div class="space-y-5 relative z-10">
                                <!-- Item 1 -->
                                <div class="flex items-start space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-emerald-500/20 border border-emerald-500/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="fa-solid fa-check text-emerald-500 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-white">Resultados oficiales ingresados</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">Austria vs Spain</p>
                                        <p class="text-[9px] text-slate-500 mt-1 font-medium">Hace 15 min</p>
                                    </div>
                                </div>
                                <!-- Item 2 -->
                                <div class="flex items-start space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-500/20 border border-blue-500/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="fa-solid fa-user-plus text-blue-500 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-white">Nuevo usuario registrado</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">juan.perez@email.com</p>
                                        <p class="text-[9px] text-slate-500 mt-1 font-medium">Hace 32 min</p>
                                    </div>
                                </div>
                                <!-- Item 3 -->
                                <div class="flex items-start space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-purple-500/20 border border-purple-500/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="fa-solid fa-pen-to-square text-purple-500 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-white">Predicciones actualizadas</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">5 usuarios modificaron sus predicciones</p>
                                        <p class="text-[9px] text-slate-500 mt-1 font-medium">Hace 1 hora</p>
                                    </div>
                                </div>
                                <!-- Item 4 -->
                                <div class="flex items-start space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-amber-500/20 border border-amber-500/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="fa-solid fa-trophy text-amber-500 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-white">Puntos recalculados</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">Sistema automático ejecutado</p>
                                        <p class="text-[9px] text-slate-500 mt-1 font-medium">Hace 2 horas</p>
                                    </div>
                                </div>
                                <!-- Item 5 -->
                                <div class="flex items-start space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-sky-500/20 border border-sky-500/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="fa-solid fa-clipboard-list text-sky-500 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-white">Partido reprogramado</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">Brazil vs Argentina</p>
                                        <p class="text-[9px] text-slate-500 mt-1 font-medium">Hace 3 horas</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <a href="#" class="mt-4 block w-full py-2.5 border border-slate-700 text-slate-400 hover:bg-slate-800 hover:text-white text-xs font-bold text-center rounded-xl transition-colors">
                            <i class="fa-regular fa-eye mr-1"></i> Ver toda la actividad
                        </a>
                    </div>
                </div>

                <!-- 3. Gráficas y Estadísticas -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    
                    <!-- Gráfica de Líneas -->
                    <div class="lg:col-span-1 bg-slate-900/70 border border-white/5 rounded-2xl p-6 backdrop-blur-md shadow-xl flex flex-col justify-between">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-sm font-bold text-white">Estadísticas Generales</h3>
                        </div>
                        <div class="h-48 w-full mt-4">
                            <canvas id="lineChart"></canvas>
                        </div>
                    </div>

                    <!-- Gráfica de Anillo -->
                    <div class="lg:col-span-1 bg-slate-900/70 border border-white/5 rounded-2xl p-6 backdrop-blur-md shadow-xl flex flex-col justify-between">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-sm font-bold text-white">Predicciones por Estado</h3>
                        </div>
                        <div class="flex items-center justify-between mt-4">
                            <!-- Contenedor del Canvas -->
                            <div class="relative w-32 h-32 flex-shrink-0">
                                <canvas id="donutChart"></canvas>
                                <!-- Texto en el centro del donut -->
                                <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                                    <span class="text-sm font-black text-white"><%= metrics.totalPredictions.toLocaleString() %></span>
                                    <span class="text-[8px] text-slate-400 font-bold uppercase tracking-widest">Total</span>
                                </div>
                            </div>
                            
