    <!-- Scripts para Gráficas Chart.js -->
    <script>
        // Configuración Global de Chart.js para Dark Mode
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.font.family = 'Inter, ui-sans-serif, system-ui, sans-serif';
        
        // 1. Gráfica de Líneas (Estadísticas Generales)
        const lineCtx = document.getElementById('lineChart').getContext('2d');
        
        // Crear gradiente para el área bajo la línea azul
        const blueGradient = lineCtx.createLinearGradient(0, 0, 0, 200);
        blueGradient.addColorStop(0, 'rgba(59, 130, 246, 0.5)'); // blue-500
        blueGradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

        // Crear gradiente para el área bajo la línea dorada
        const amberGradient = lineCtx.createLinearGradient(0, 0, 0, 200);
        amberGradient.addColorStop(0, 'rgba(245, 158, 11, 0.5)'); // amber-500
        amberGradient.addColorStop(1, 'rgba(245, 158, 11, 0.0)');

        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: ['19 May', '20 May', '21 May', '22 May', '23 May', '24 May', '25 May'],
                datasets: [
                    {
                        label: 'Predicciones',
                        data: [2000, 3500, 4200, 5800, 7100, 11000, 15892],
                        borderColor: '#3b82f6', // blue-500
                        backgroundColor: blueGradient,
                        borderWidth: 2,
                        tension: 0.4, // Curva suave
                        fill: true,
                        pointBackgroundColor: '#1e3a8a',
                        pointBorderColor: '#3b82f6',
                        pointBorderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5
                    },
                    {
                        label: 'Usuarios',
                        data: [500, 800, 950, 1100, 1150, 1200, 1248],
                        borderColor: '#f59e0b', // amber-500
                        backgroundColor: amberGradient,
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#78350f',
                        pointBorderColor: '#f59e0b',
                        pointBorderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        align: 'center',
                        labels: {
                            boxWidth: 10,
                            usePointStyle: true,
                            pointStyle: 'rectRounded',
                            padding: 20,
                            font: { size: 10, weight: 'bold' }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleColor: '#fff',
                        bodyColor: '#cbd5e1',
                        borderColor: 'rgba(255,255,255,0.1)',
                        borderWidth: 1,
                        padding: 10,
                        displayColors: true,
                        usePointStyle: true,
                    }
                },
                scales: {
                    x: {
                        grid: { display: false, drawBorder: false },
                        ticks: { font: { size: 9 } }
                    },
                    y: {
                        grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                        ticks: { 
                            font: { size: 9 },
                            callback: function(value) { return value >= 1000 ? (value/1000) + 'k' : value; }
                        },
                        beginAtZero: true
                    }
                },
                interaction: {
                    mode: 'index',
                    intersect: false,
                }
            }
        });

        // 2. Gráfica de Anillo (Predicciones por Estado)
        const donutCtx = document.getElementById('donutChart').getContext('2d');
        new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                labels: ['Pendientes', 'Calculadas', 'Sin calcular'],
                datasets: [{
                    data: [6124, 8902, 866],
                    backgroundColor: [
                        '#3b82f6', // blue-500
                        '#10b981', // emerald-500
                        '#f59e0b'  // amber-500
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%', // Tamaño del hueco interior
                plugins: {
                    legend: { display: false }, // Ocultar leyenda por defecto (creamos una custom en HTML)
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        bodyFont: { size: 11, weight: 'bold' },
                        padding: 8,
                        displayColors: true,
                        usePointStyle: true,
                    }
                }
            }
        });
    </script>
