<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listado de Partidos | Quiniela Mundial 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="bg-cover bg-center bg-no-repeat bg-fixed font-sans min-h-screen relative" style="background-image: url('/images/stadium_bg.jpeg');">
    
    <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm z-0"></div>

    <div class="flex h-screen relative z-10 overflow-hidden">

        <%- include('../partials/admin_sidebar', { activePage: 'matches' }) %>

        <main class="flex-1 flex flex-col overflow-y-auto">
            
            <header class="bg-slate-900/60 border-b border-slate-800 px-8 py-4 flex justify-between items-center backdrop-blur-md">
                <h1 class="text-xl font-extrabold text-white">Listado Global de Partidos</h1>
                <div class="text-sm text-slate-400 font-medium">Fútbol Mundial 2026</div>
            </header>

            <div class="p-8">
                <% if (success) { %>
                    <div class="bg-emerald-500/20 border border-emerald-500/50 text-emerald-300 p-4 rounded-xl backdrop-blur-sm font-semibold flex items-center space-x-2 mb-6">
                        <i class="fa-solid fa-circle-check text-xl"></i>
                        <span>¡Límite de predicciones actualizado con éxito!</span>
                    </div>
                <% } %>
                <div class="bg-slate-900/80 border border-slate-800 rounded-2xl p-6 backdrop-blur-md shadow-xl">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-base font-bold text-white flex items-center space-x-2">
                            <i class="fa-solid fa-calendar-days text-amber-500"></i>
                            <span>Todos los Partidos Registrados</span>
                        </h3>
                        <a href="/admin/matches/center" class="text-xs bg-blue-600 hover:bg-blue-500 text-white font-bold px-4 py-2 rounded-lg shadow-md transition-all">
                            Ingresar Resultados
                        </a>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm text-slate-300">
                            <thead class="text-xs uppercase text-slate-400 bg-slate-950/50 rounded-lg">
                                <tr>
                                    <th scope="col" class="px-6 py-3 rounded-l-lg">ID</th>
                                    <th scope="col" class="px-6 py-3">Fase</th>
                                    <th scope="col" class="px-6 py-3">Confrontación</th>
                                    <th scope="col" class="px-6 py-3 text-center">Fecha y Hora (VET)</th>
                                    <th scope="col" class="px-6 py-3 text-center">Estado</th>
                                    <th scope="col" class="px-6 py-3 text-center">Límite de Predicción</th>
                                    <th scope="col" class="px-6 py-3 text-center rounded-r-lg">Marcador Real</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/60 font-medium">
                                <% matches.forEach(match => { %>
                                    <tr class="hover:bg-slate-800/40 transition-colors">
                                        <td class="px-6 py-4 font-bold text-slate-400">#<%= match.id %></td>
                                        <td class="px-6 py-4 text-white"><%= match.stage %></td>
                                        <td class="px-6 py-4 font-extrabold text-white">
                                            <%= match.home_team %> vs <%= match.away_team %>
                                        </td>
                                        <td class="px-6 py-4 text-center text-slate-400">
                                            <%= new Date(match.kickoff_time).toLocaleDateString('es-VE', {day:'2-digit', month:'short'}) %> -
                                            <%= new Date(match.kickoff_time).toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'}) %>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <% if (match.status === 'finished') { %>
                                                <span class="text-[10px] px-2.5 py-0.5 rounded-full font-black uppercase bg-slate-800 text-slate-400 border border-slate-700">
                                                    Finalizado
                                                </span>
                                            <% } else if (match.status === 'live') { %>
                                                <span class="text-[10px] px-2.5 py-0.5 rounded-full font-black uppercase bg-red-500/20 text-red-400 border border-red-500/30 animate-pulse">
                                                    En Vivo
                                                </span>
                                            <% } else { %>
                                                <span class="text-[10px] px-2.5 py-0.5 rounded-full font-black uppercase bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">
                                                    Programado
                                                </span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <% if (match.status === 'finished') { %>
                                                <span class="text-[10px] uppercase font-bold text-slate-500">Cerrado (Finalizado)</span>
                                            <% } else { %>
                                                <div class="flex flex-col items-center space-y-2">
                                                    <!-- Mostrar estado actual -->
                                                    <div class="text-[10px] font-bold">
                                                        <% if (match.prediction_deadline) { %>
                                                            <% if (new Date() >= new Date(match.prediction_deadline)) { %>
                                                                <span class="text-red-400 bg-red-950/40 px-2.5 py-1 rounded border border-red-900/50">Límite manual expirado</span>
                                                            <% } else { %>
                                                                <span class="text-amber-400 bg-amber-950/40 px-2.5 py-1 rounded border border-amber-900/50 animate-pulse">Abierto hasta: <%= new Date(match.prediction_deadline).toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'}) %></span>
                                                            <% } %>
                                                        <% } else { %>
                                                            <span class="text-slate-400 bg-slate-950/40 px-2.5 py-1 rounded border border-slate-900/50">Estándar (Hora Inicio)</span>
                                                        <% } %>
                                                    </div>
                                                    
                                                    <!-- Selector rápido -->
                                                    <form action="/admin/matches/override-deadline" method="POST" class="w-full max-w-[150px]">
                                                        <input type="hidden" name="matchId" value="<%= match.id %>">
                                                        <select name="durationMinutes" onchange="this.form.submit()" 
                                                                class="bg-slate-950 border border-slate-800 text-[10px] rounded p-1 text-slate-300 w-full focus:outline-none focus:border-blue-500 cursor-pointer">
                                                            <option value="" disabled selected>Modificar límite...</option>
                                                            <option value="15">Habilitar 15 min</option>
                                                            <option value="30">Habilitar 30 min</option>
                                                            <option value="60">Habilitar 1 hora</option>
                                                            <option value="120">Habilitar 2 horas</option>
                                                            <option value="1440">Habilitar 24 horas</option>
                                                            <option value="close">Cerrar ahora</option>
                                                            <option value="reset">Restablecer estándar</option>
                                                        </select>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <% if (match.status === 'finished') { %>
                                                <span class="text-base font-black text-blue-400 bg-blue-500/5 px-3 py-1 rounded-lg border border-blue-500/10">
                                                    <%= match.home_score_actual %> - <%= match.away_score_actual %>
                                                </span>
                                            <% } else { %>
                                                <span class="text-slate-600">-</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
