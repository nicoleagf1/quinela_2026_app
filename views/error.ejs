<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Error | Quiniela 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 text-gray-900 font-sans flex flex-col min-h-screen">
    <%- include('partials/header') %>
    <main class="flex-grow max-w-6xl mx-auto px-4 py-8 w-full text-center">
        <h1 class="text-3xl font-extrabold text-red-600 mb-4">Ha ocurrido un error</h1>
        <div class="bg-red-50 p-6 shadow-md rounded-xl border border-red-200 inline-block">
            <p class="text-lg text-red-800"><%= mensaje %></p>
            <a href="/" class="mt-4 inline-block bg-blue-600 text-white px-4 py-2 rounded font-bold hover:bg-blue-700">Volver al Inicio</a>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
