<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Partidos | Quiniela 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-gray-50 text-gray-900 font-sans flex flex-col min-h-screen">
    <%- include('partials/header') %>
    <main class="flex-grow max-w-6xl mx-auto px-4 py-8 w-full">
        <h1 class="text-3xl font-extrabold text-blue-900 mb-6">Cartelera de Partidos</h1>
        <% if (error) { %>
            <div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="bg-emerald-100 text-emerald-700 p-3 rounded mb-4">¡Pronóstico guardado exitosamente!</div>
        <% } %>
        <% const dates = Object.keys(groupedMatches); %>
        <% if (dates.length === 0) { %>
            <p class="text-gray-500 text-lg text-center mt-12">No hay partidos disponibles.</p>
        <% } else { %>
            <% dates.forEach(dateStr => { %>
                <div class="mb-10">
                    <h2 class="text-2xl font-bold text-gray-700 mb-4 pb-2 border-b-2 border-blue-900 inline-block"><%= dateStr %></h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% groupedMatches[dateStr].forEach(match => { %>
                            <div class="bg-white p-5 shadow-lg rounded-2xl border border-gray-100 hover:shadow-xl transition-shadow duration-300">
                                <div class="flex justify-between items-center mb-4 border-b border-gray-100 pb-2">
                                    <span class="text-xs font-bold uppercase tracking-wider text-blue-600"><%= match.stage %></span>
                                    <span class="text-sm font-semibold text-gray-500 bg-gray-100 px-2 py-1 rounded"><%= new Date(match.kickoff_time).toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit' }) %></span>
                                </div>
                                <form action="/predictions" method="POST" class="flex flex-col items-center">
                                    <input type="hidden" name="matchId" value="<%= match.id %>">
                                    <div class="flex w-full justify-between items-center mb-6">
                                        <div class="text-center w-5/12">
                                            <p class="font-extrabold text-lg text-gray-800 break-words leading-tight"><%= match.home_team %></p>
                                        </div>
                                        <div class="flex items-center space-x-1 w-2/12 justify-center">
                                            <input type="number" name="homeScore" class="w-10 text-center border-2 border-gray-200 rounded-lg p-1 text-xl font-bold focus:border-blue-500 focus:outline-none transition-colors" min="0" required 
                                                   value="<%= match.home_score_predicted !== null ? match.home_score_predicted : '' %>">
                                            <span class="font-bold text-gray-400">-</span>
                                            <input type="number" name="awayScore" class="w-10 text-center border-2 border-gray-200 rounded-lg p-1 text-xl font-bold focus:border-blue-500 focus:outline-none transition-colors" min="0" required
                                                   value="<%= match.away_score_predicted !== null ? match.away_score_predicted : '' %>">
                                        </div>
                                        <div class="text-center w-5/12">
                                            <p class="font-extrabold text-lg text-gray-800 break-words leading-tight"><%= match.away_team %></p>
                                        </div>
                                    </div>
                                    <button type="submit" class="w-full <%= match.home_score_predicted !== null ? 'bg-amber-500 hover:bg-amber-600' : 'bg-blue-600 hover:bg-blue-700' %> text-white px-6 py-3 rounded-xl font-bold transition-all shadow-md active:scale-95">
                                        <%= match.home_score_predicted !== null ? 'Actualizar Pronóstico' : 'Guardar Pronóstico' %>
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
