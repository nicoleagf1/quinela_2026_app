<nav class="bg-slate-950/90 backdrop-blur-md border-b border-white/10 text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row md:justify-between items-center space-y-4 md:space-y-0">
    <a href="/" class="flex items-center space-x-3">
        <i class="fa-solid fa-trophy text-amber-500 text-2xl drop-shadow-md"></i>
        <span class="text-xl font-bold tracking-wider">Quiniela <span class="text-amber-500">2026</span></span>
    </a>
    <div class="flex items-center space-x-6 md:space-x-8 text-sm font-semibold overflow-x-auto hide-scrollbar whitespace-nowrap pl-4 md:pl-0">
      <% if (user) { %>
        <% const current = typeof activePage !== 'undefined' ? activePage : ''; %>
        <a href="/dashboard" class="transition-colors pb-1 border-b-2 <%= current === 'dashboard' ? 'text-amber-500 border-amber-500' : 'text-slate-300 border-transparent hover:text-amber-400' %>">Inicio</a>
        <a href="/matches" class="transition-colors pb-1 border-b-2 <%= current === 'matches' ? 'text-amber-500 border-amber-500' : 'text-slate-300 border-transparent hover:text-amber-400' %>">Partidos</a>
        <a href="/auditoria" class="transition-colors pb-1 border-b-2 <%= current === 'auditoria' ? 'text-amber-500 border-amber-500' : 'text-slate-300 border-transparent hover:text-amber-400' %>">Auditoría</a>
        <a href="/leaderboard" class="transition-colors pb-1 border-b-2 <%= current === 'leaderboard' ? 'text-amber-500 border-amber-500' : 'text-slate-300 border-transparent hover:text-amber-400' %>">Posiciones</a>
        
        <% if (user.role === 'admin') { %>
          <a href="/admin/dashboard" class="transition-colors pb-1 border-b-2 text-slate-300 border-transparent hover:text-amber-400">Admin</a>
        <% } %>
        
        <a href="/logout" class="transition-colors pb-1 text-slate-400 hover:text-red-400 ml-4">Cerrar Sesión</a>
        
        <div class="w-9 h-9 rounded-full bg-blue-600 flex items-center justify-center font-black text-white ml-2 shadow-[0_0_15px_rgba(37,99,235,0.5)] border border-blue-400/50">
            <%= user.first_name ? user.first_name.charAt(0).toUpperCase() : 'U' %>
        </div>
      <% } else { %>
        <a href="/login" class="hover:text-amber-400 transition-colors text-slate-300">Ingresar</a>
        <a href="/register" class="bg-blue-600 hover:bg-blue-500 px-5 py-2.5 rounded-md transition-colors text-white shadow-lg">Registrarse</a>
      <% } %>
    </div>
  </div>
</nav>
