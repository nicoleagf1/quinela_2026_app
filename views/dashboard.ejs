<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inicio | Quiniela Mundial 2026</title>
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts: Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="w-full min-h-screen text-slate-100 font-sans relative overflow-x-hidden bg-slate-950 flex flex-col">
    
    <%- include('partials/header') %>

    <main class="flex-grow w-full flex flex-col">
        
        <!-- Hero Section -->
        <section class="relative w-full h-[450px] flex items-center justify-start overflow-hidden">
            <!-- Background Image -->
            <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/hero_bg.jpeg');"></div>
            <!-- Gradients for blending -->
            <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/80 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent"></div>
            
            <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
                <div class="max-w-2xl">
                    <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-tight mb-4 drop-shadow-lg">
                        ¡BIENVENIDO, <span class="text-amber-500"><%= user.first_name.toUpperCase() %>!</span>
                    </h1>
                    <p class="text-lg md:text-xl text-slate-300 mb-8 font-medium max-w-lg drop-shadow-md">
                        Demuestra quién sabe más de fútbol.<br>
                        Haz tus pronósticos, suma puntos<br>
                        y compite por el primer lugar.
                    </p>
                    <div class="flex items-center space-x-4">
                        <a href="/matches" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-md shadow-[0_0_15px_rgba(37,99,235,0.4)] transition-all flex items-center space-x-2">
                            <i class="fa-regular fa-calendar"></i>
                            <span>Ver Partidos</span>
                        </a>
                        <a href="/leaderboard" class="bg-amber-500 hover:bg-amber-400 text-slate-950 font-black py-3 px-6 rounded-md shadow-[0_0_15px_rgba(245,158,11,0.4)] transition-all flex items-center space-x-2">
                            <i class="fa-solid fa-trophy"></i>
                            <span>Tabla General</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <div class="max-w-7xl mx-auto px-6 w-full -mt-10 relative z-20 pb-12">
            
            <!-- 4 Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
                <!-- Tarjeta 1: Partidos -->
                <div class="bg-slate-900/90 backdrop-blur-md border border-white/5 rounded-lg p-5 flex items-center space-x-4 shadow-xl">
                    <div class="w-12 h-12 rounded-md bg-blue-600 flex items-center justify-center shadow-lg">
                        <i class="fa-solid fa-soccer-ball text-white text-xl"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Partidos</p>
                        <p class="text-3xl font-black text-white leading-none mt-1"><%= stats.totalMatches %></p>
                        <p class="text-[10px] text-slate-500 mt-1">Total de partidos</p>
                    </div>
                </div>
                
                <!-- Tarjeta 2: Mis Puntos -->
                <div class="bg-slate-900/90 backdrop-blur-md border border-white/5 rounded-lg p-5 flex items-center space-x-4 shadow-xl">
                    <div class="w-12 h-12 rounded-md bg-emerald-600 flex items-center justify-center shadow-lg">
                        <i class="fa-solid fa-chart-line text-white text-xl"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Mis Puntos</p>
                        <p class="text-3xl font-black text-white leading-none mt-1"><%= stats.userPoints %></p>
                        <p class="text-[10px] text-slate-500 mt-1">Puntos totales</p>
                    </div>
                </div>

                <!-- Tarjeta 3: Mi Posición -->
                <div class="bg-slate-900/90 backdrop-blur-md border border-white/5 rounded-lg p-5 flex items-center space-x-4 shadow-xl">
                    <div class="w-12 h-12 rounded-md bg-purple-600 flex items-center justify-center shadow-lg">
                        <i class="fa-solid fa-ranking-star text-white text-xl"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Mi Posición</p>
                        <p class="text-3xl font-black text-white leading-none mt-1"><%= stats.userPosition %>°</p>
                        <p class="text-[10px] text-slate-500 mt-1">De <%= stats.totalUsers %> participantes</p>
                    </div>
                </div>

                <!-- Tarjeta 4: Jugadores -->
                <div class="bg-slate-900/90 backdrop-blur-md border border-white/5 rounded-lg p-5 flex items-center space-x-4 shadow-xl">
                    <div class="w-12 h-12 rounded-md bg-orange-600 flex items-center justify-center shadow-lg">
                        <i class="fa-solid fa-users text-white text-xl"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Jugadores</p>
                        <p class="text-3xl font-black text-white leading-none mt-1"><%= stats.totalUsers %></p>
                        <p class="text-[10px] text-slate-500 mt-1">Participantes</p>
                    </div>
                </div>
            </div>

            <!-- 3 Columns Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <!-- Columna 1: Próximos Partidos -->
                <div class="bg-slate-900/70 border border-white/5 rounded-xl p-6 backdrop-blur-sm">
                    <h3 class="text-sm font-bold text-slate-200 uppercase tracking-widest mb-6 flex items-center space-x-2">
                        <i class="fa-regular fa-calendar text-slate-400"></i>
                        <span>Próximos Partidos</span>
                    </h3>
                    
                    <div class="space-y-4">
                        <% if(upcomingMatches.length === 0) { %>
                            <p class="text-slate-500 text-sm text-center py-4">No hay partidos próximos.</p>
                        <% } %>
                        <% upcomingMatches.forEach(match => { %>
                            <div class="bg-slate-950/60 border border-white/5 rounded-lg p-4 transition-colors hover:border-white/10">
                                <div class="flex items-center justify-between mb-4">
                                    <!-- Home -->
                                    <div class="flex items-center space-x-3 w-5/12">
                                        <% if(teamData[match.home_team]) { %>
                                            <img src="https://flagcdn.com/w40/<%= teamData[match.home_team].iso %>.png" class="w-6 h-4 object-cover rounded-sm" alt="Flag">
                                        <% } %>
                                        <span class="text-xs font-black text-white truncate uppercase"><%= match.home_team %></span>
                                    </div>
                                    
                                    <span class="text-xs font-bold text-slate-500 px-2">VS</span>

                                    <!-- Away -->
                                    <div class="flex items-center space-x-3 w-5/12 flex-row-reverse">
                                        <% if(teamData[match.away_team]) { %>
                                            <img src="https://flagcdn.com/w40/<%= teamData[match.away_team].iso %>.png" class="w-6 h-4 object-cover rounded-sm ml-3" alt="Flag">
                                        <% } %>
                                        <span class="text-xs font-black text-white truncate uppercase"><%= match.away_team %></span>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between text-[10px] text-slate-400">
                                    <div class="flex items-center space-x-3">
                                        <span><i class="fa-regular fa-calendar mr-1"></i> <%= new Date(match.kickoff_time).toLocaleDateString('es-VE') %></span>
                                        <span><i class="fa-regular fa-clock mr-1"></i> <%= new Date(match.kickoff_time).toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'}) %> hrs</span>
                                    </div>
                                    <a href="/matches" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-1.5 px-3 rounded text-[10px] transition-colors">
                                        Pronosticar
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Columna 2: Tabla General -->
                <div class="bg-slate-900/70 border border-white/5 rounded-xl p-6 backdrop-blur-sm flex flex-col">
                    <h3 class="text-sm font-bold text-slate-200 uppercase tracking-widest mb-6 flex items-center space-x-2">
                        <i class="fa-solid fa-trophy text-slate-400"></i>
                        <span>Tabla General</span>
                    </h3>

                    <div class="flex-grow space-y-2">
                        <% topLeaderboard.forEach((userItem, index) => { %>
                            <div class="flex items-center justify-between py-2 border-b border-white/5 last:border-0">
                                <div class="flex items-center space-x-4">
                                    <!-- Rank Number -->
                                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-black
                                        <%= index === 0 ? 'bg-amber-500 text-slate-950' : 
                                           index === 1 ? 'bg-slate-300 text-slate-950' : 
                                           index === 2 ? 'bg-amber-700 text-white' : 'bg-slate-800 text-slate-400' %>">
                                        <%= index + 1 %>
                                    </div>
                                    <!-- Avatar -->
                                    <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white
                                        <%= index === 0 ? 'bg-purple-600' : index === 1 ? 'bg-blue-600' : index === 2 ? 'bg-emerald-600' : 'bg-slate-700' %>">
                                        <%= userItem.first_name.charAt(0).toUpperCase() %>
                                    </div>
                                    <!-- Name -->
                                    <span class="text-sm font-bold text-white"><%= userItem.first_name %></span>
                                </div>
                                <div class="text-sm font-black <%= index === 0 ? 'text-amber-500' : 'text-white' %>">
                                    <%= userItem.total_points %> <span class="text-[10px] text-slate-500">pts</span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                    
                    <a href="/leaderboard" class="mt-6 w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 rounded-md text-center text-xs transition-colors">
                        Ver tabla completa
                    </a>
                </div>

                <!-- Columna 3: Estadísticas y Resultados -->
                <div class="space-y-6">
                    
                    <!-- Mis Estadísticas -->
                    <div class="bg-slate-900/70 border border-white/5 rounded-xl p-6 backdrop-blur-sm">
                        <h3 class="text-sm font-bold text-slate-200 uppercase tracking-widest mb-6 flex items-center space-x-2">
                            <i class="fa-solid fa-chart-line text-slate-400"></i>
                            <span>Mis Estadísticas</span>
                        </h3>
                        
                        <div class="space-y-5">
                            <% 
                                const total = stats.userStats ? parseInt(stats.userStats.total_predictions) : 0;
                                const correct = stats.userStats ? parseInt(stats.userStats.correct_predictions) : 0;
                                const percentCorrect = total > 0 ? Math.round((correct / total) * 100) : 0;
                                const percentPredicted = Math.round((total / stats.totalMatches) * 100);
                            %>
                            
                            <div>
                                <div class="flex justify-between text-xs font-bold text-white mb-1">
                                    <span>Partidos acertados</span>
                                    <span class="text-lg"><%= percentCorrect %>%</span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-1.5">
                                    <div class="bg-emerald-500 h-1.5 rounded-full" style="width: <%= percentCorrect %>%"></div>
                                </div>
                            </div>

                            <div>
                                <div class="flex justify-between text-xs font-bold text-white mb-1">
                                    <span>Pronósticos realizados</span>
                                    <span class="text-lg"><%= total %> / <%= stats.totalMatches %></span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-1.5">
                                    <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= percentPredicted %>%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Últimos Resultados -->
                    <div class="bg-slate-900/70 border border-white/5 rounded-xl p-6 backdrop-blur-sm">
                        <h3 class="text-sm font-bold text-slate-200 uppercase tracking-widest mb-4 flex items-center space-x-2">
                            <i class="fa-solid fa-sitemap text-slate-400"></i>
                            <span>Últimos Resultados</span>
                        </h3>
                        
                        <div class="space-y-3 mb-4">
                            <% if(recentMatches.length === 0) { %>
                                <p class="text-slate-500 text-xs text-center">Aún no hay resultados.</p>
                            <% } %>
                            <% recentMatches.forEach(match => { %>
                                <div class="flex items-center justify-between text-xs font-bold">
                                    <div class="flex items-center space-x-2 w-5/12">
                                        <% if(teamData[match.home_team]) { %>
                                            <img src="https://flagcdn.com/w40/<%= teamData[match.home_team].iso %>.png" class="w-4 h-3 object-cover rounded-[1px]" alt="Flag">
                                        <% } %>
                                        <span class="text-white uppercase truncate"><%= match.home_team %></span>
                                    </div>
                                    
                                    <div class="w-2/12 flex justify-center">
                                        <div class="bg-emerald-600 text-white px-2 py-0.5 rounded shadow-sm text-center font-black">
                                            <%= match.home_score_actual %> - <%= match.away_score_actual %>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center space-x-2 w-5/12 flex-row-reverse">
                                        <% if(teamData[match.away_team]) { %>
                                            <img src="https://flagcdn.com/w40/<%= teamData[match.away_team].iso %>.png" class="w-4 h-3 object-cover rounded-[1px] ml-2" alt="Flag">
                                        <% } %>
                                        <span class="text-white uppercase truncate"><%= match.away_team %></span>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                        
                        <a href="/matches" class="text-[10px] text-blue-400 hover:text-blue-300 w-full text-center block transition-colors">
                            Ver todos los resultados
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <div class="relative z-20 border-t border-white/10 bg-slate-950/90">
        <%- include('partials/footer') %>
    </div>
</body>
</html>
